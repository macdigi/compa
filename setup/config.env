# Compa Configuration
# Edit these values for your setup

# Mac Mini network sample library
MAC_MINI_IP=192.168.1.XXX
MAC_MINI_USER=charlie
REMOTE_SAMPLE_DIR=/Users/charlie/Music/Samples

# Local paths
LOCAL_SAMPLE_CACHE=/home/pi/compa/samples

# Audio settings
AUDIO_DEVICE=default
BUFFER_SIZE=256
SAMPLE_RATE=44100
MONITOR_GAIN=1.5

# MIDI settings
MIDI_BASE_NOTE=36
P6_AUTO_RECORD=1
SP404_DIRECT_FX_1=Super Filter
SP404_DIRECT_FX_2=Compressor
SP404_DIRECT_FX_3=Back Spin
UI_FPS=60
SCOPE_POINTS=1280
SCOPE_WINDOW_FRAMES=2048
